generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://forumuser:ForumPass123@124.220.65.225:3306/teamagentx_forum"
}

model categories {
  id          String   @id
  name        String
  slug        String   @unique
  description String?
  order       Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime
  posts       posts[]
}

model comments {
  id             String          @id
  content        String          @db.Text
  author_id      String
  post_id        String
  parent_id      String?
  like_count     Int             @default(0)
  status         comments_status @default(NORMAL)
  created_at     DateTime        @default(now())
  updated_at     DateTime
  users          users           @relation(fields: [author_id], references: [id])
  comments       comments?       @relation("commentsTocomments", fields: [parent_id], references: [id])
  other_comments comments[]      @relation("commentsTocomments")
  posts          posts           @relation(fields: [post_id], references: [id])
  likes          likes[]
  reports        reports[]

  @@index([author_id])
  @@index([created_at])
  @@index([parent_id])
  @@index([post_id])
}

model favorites {
  id         String   @id
  user_id    String
  post_id    String
  created_at DateTime @default(now())
  posts      posts    @relation(fields: [post_id], references: [id])
  users      users    @relation(fields: [user_id], references: [id])

  @@unique([user_id, post_id])
  @@index([post_id], map: "favorites_post_id_fkey")
}

model likes {
  id         String    @id
  user_id    String
  post_id    String?
  comment_id String?
  created_at DateTime  @default(now())
  comments   comments? @relation(fields: [comment_id], references: [id])
  posts      posts?    @relation(fields: [post_id], references: [id])
  users      users     @relation(fields: [user_id], references: [id])

  @@unique([user_id, comment_id])
  @@unique([user_id, post_id])
  @@index([comment_id], map: "likes_comment_id_fkey")
  @@index([post_id], map: "likes_post_id_fkey")
}

model post_limits {
  id         String   @id
  user_id    String
  date       DateTime
  count      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime

  @@unique([user_id, date])
}

model posts {
  id            String       @id
  title         String
  content       String       @db.Text
  author_id     String
  category_id   String
  is_top        Boolean      @default(false)
  is_essence    Boolean      @default(false)
  view_count    Int          @default(0)
  like_count    Int          @default(0)
  comment_count Int          @default(0)
  status        posts_status @default(NORMAL)
  created_at    DateTime     @default(now())
  updated_at    DateTime
  comments      comments[]
  favorites     favorites[]
  likes         likes[]
  users         users        @relation(fields: [author_id], references: [id])
  categories    categories   @relation(fields: [category_id], references: [id])
  reports       reports[]

  @@index([author_id])
  @@index([category_id])
  @@index([created_at])
  @@index([is_essence])
  @@index([is_top])
}

model reports {
  id          String         @id
  user_id     String
  post_id     String?
  comment_id  String?
  reason      reports_reason
  description String?
  status      reports_status @default(PENDING)
  created_at  DateTime       @default(now())
  updated_at  DateTime
  comments    comments?      @relation(fields: [comment_id], references: [id])
  posts       posts?         @relation(fields: [post_id], references: [id])
  users       users          @relation(fields: [user_id], references: [id])

  @@unique([user_id, comment_id])
  @@unique([user_id, post_id])
  @@index([comment_id], map: "reports_comment_id_fkey")
  @@index([post_id], map: "reports_post_id_fkey")
  @@index([status])
}

model users {
  id             String      @id
  email          String      @unique
  password       String
  nickname       String?
  avatar         String?
  role           users_role  @default(USER)
  email_verified Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime
  comments       comments[]
  favorites      favorites[]
  likes          likes[]
  posts          posts[]
  reports        reports[]
}

enum reports_reason {
  SPAM
  ATTACK
  PLAGIARISM
  OTHER
}

enum users_role {
  USER
  ADMIN
}

enum comments_status {
  NORMAL
  DELETED
}

enum reports_status {
  PENDING
  RESOLVED
  REJECTED
}

enum posts_status {
  NORMAL
  DELETED
}
